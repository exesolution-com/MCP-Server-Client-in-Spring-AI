# ============================================================
# Environment variables for mcp-solution Docker Compose
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# Required: OpenAI API key (or any OpenAI-compatible endpoint key)
OPENAI_API_KEY=sk-your-key-here

# Optional: override the MCP server URL (default: http://mcp-tool-server:8080)
# MCP_SERVER_URL=http://mcp-tool-server:8080

# Optional: admin password overrides (change in production)
# MCP_ADMIN_PASSWORD=admin-secret
# CHAT_USER_PASSWORD=user-secret
